{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aivatar",
  "version": "0.1.0",
  "identifier": "com.aivatar.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aivatar",
        "label": "main",
        "width": 760,
        "height": 520,
        "minWidth": 720,
        "minHeight": 500,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png"],
    "resources": ["../plugins/aivatar-session-bridge/", "../scripts/"],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      }
    }
  }
}
